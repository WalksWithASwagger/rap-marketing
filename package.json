{
  "name": "rap-marketing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "optimize:images": "node scripts/optimize-images.mjs",
    "lighthouse": "lhci autorun",
    "axe": "node scripts/run-axe.mjs",
    "axe:serve": "next start & SERVER_PID=$!; npx wait-on http://localhost:3000 && node scripts/run-axe.mjs; STATUS=$?; kill $SERVER_PID; exit $STATUS",
    "audit": "npm run build && npm run lighthouse; npm run axe:serve"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lenis": "^1.3.23",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-sitemap": "^4.2.3",
    "plaiceholder": "^3.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@axe-core/puppeteer": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "puppeteer": "^24.43.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  }
